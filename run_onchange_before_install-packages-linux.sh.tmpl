#!/usr/bin/env bash
{{- if ne .chezmoi.os "linux" }}
exit 0
{{- end }}

set -u

MISSING_FILE="${HOME}/pacchetti-mancanti.txt"
FAILED_FILE="${HOME}/pacchetti-falliti.txt"
mkdir -p "${HOME}/.config/chezmoi"
: > "$MISSING_FILE"
: > "$FAILED_FILE"

append_unique() {
  local file="$1"
  local value="$2"
  grep -Fxq "$value" "$file" 2>/dev/null || echo "$value" >> "$file"
}

install_apt_pkg() {
  local pkg="$1"

  if apt-cache show "$pkg" >/dev/null 2>&1; then
    if dpkg -s "$pkg" >/dev/null 2>&1; then
      echo "[apt] già installato: $pkg"
    else
      echo "[apt] installo: $pkg"
      if ! sudo apt-get install -y "$pkg"; then
        echo "[apt] fallito: $pkg"
        append_unique "$FAILED_FILE" "apt:$pkg"
      fi
    fi
  else
    echo "[apt] assente nei repo: $pkg"
    append_unique "$MISSING_FILE" "apt:$pkg"
  fi
}

install_flatpak_app() {
  local app="$1"

  if flatpak info "$app" >/dev/null 2>&1; then
    echo "[flatpak] già installato: $app"
  else
    echo "[flatpak] installo: $app"
    if ! flatpak install -y flathub "$app"; then
      echo "[flatpak] fallito o assente: $app"
      append_unique "$MISSING_FILE" "flatpak:$app"
    fi
  fi
}

if command -v apt-get >/dev/null 2>&1; then
  sudo apt-get update
  {{- range .packages.linux.apt }}
  install_apt_pkg {{ . | quote }}
  {{- end }}
fi

if command -v flatpak >/dev/null 2>&1; then
  {{- range .packages.linux.flatpak }}
  install_flatpak_app {{ . | quote }}
  {{- end }}
fi

if command -v bw >/dev/null 2>&1 && [ ! -f "${HOME}/.config/chezmoi/key.txt" ]; then
  if bw get item "secret-key.txt" >/dev/null 2>&1; then
    bw get item "secret-key.txt" | jq -r '.notes' > "${HOME}/.config/chezmoi/key.txt"
    chmod 600 "${HOME}/.config/chezmoi/key.txt"
    echo "[bw] key.txt creato"
  fi
fi

sort -u "$MISSING_FILE" -o "$MISSING_FILE"
sort -u "$FAILED_FILE" -o "$FAILED_FILE"

echo
echo "===== RIEPILOGO ====="
echo "Mancanti: $MISSING_FILE"
cat "$MISSING_FILE" 2>/dev/null || true
echo
echo "Falliti: $FAILED_FILE"
cat "$FAILED_FILE" 2>/dev/null || true
