[ -f ~/.vpnua ] && source ~/.vpnua
alias ls='ls --color=auto'
#alias dir='dir --color=auto'
#alias vdir='vdir --color=auto'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias diff='diff --color=auto'
alias ip='ip --color=auto'
alias upda='sudo apt update && sudo apt upgrade -y'
alias ll='ls -l'
alias la='ls -A'
alias l='ls -CF'
alias stamp='sudo systemctl start cups'
alias ...='cd ../..'
alias ....='cd ../../..'
alias df='df -h'
alias free='free -h'
alias ports='ss -tulnp'
alias myip='curl -s ifconfig.me'
alias locip="ip -br addr"
alias path='echo $PATH | tr ":" "\n"'
alias zshrc='${EDITOR:-nvim} ~/.zshrc'
alias zalias='${EDITOR:-nvim} ~/.zsh_aliases'
alias relo='source ~/.zshrc'
alias vpnof='sudo pkill openvpn'
alias off='sudo poweroff'
alias rea='flatpak run org.libretro.RetroArch'
alias fol='flatpak run com.github.johnfactotum.Foliate'
alias sus='systemctl suspend -i'
