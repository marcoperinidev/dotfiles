####################
## Screenshots CopyQ
##
bindsym $mod+v exec --no-startup-id copyq toggle
##
## Area select -> clipboard
bindsym Shift+Insert exec --no-startup-id maim --select | copyq copy image/png -
## screenshot Area -> salva file con data
bindsym Shift+Print exec --no-startup-id maim --select "{{ .chezmoi.homeDir }}/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png"
## screenshot finestra attiva
bindsym $mod+Print exec --no-startup-id maim --window $(xdotool getactivewindow) | copyq copy image/png -
## screenshot tutto
bindsym Ctrl+Print exec --no-startup-id maim | copyq copy image/png -
