# CUSTOM CONFIG
####################
for_window [class="copyq"] floating enable
for_window [class="calculator"] floating enable

# always starting picom
exec --no-startup-id {{ .chezmoi.homeDir }}/.config/picom/launch.sh

## COLORI + impostazioni finestre
# NORD COLORS
set $bg      #2E3440
set $bg2     #3B4252
set $bg3     #434C5E
set $fg      #D8DEE9
set $blue    #81A1C1
set $lblue   #88C0D0
set $teal    #44FFCC
set $green   #A3BE8C
set $red     #BF616A
set $yellow  #EBCB8B

# window borders
default_border pixel 2
client.focused          $teal   $bg2  $fg    $teal   $teal
client.unfocused        $bg3    $bg   $fg    $bg3    $bg3
client.focused_inactive $bg3    $bg2  $fg    $bg3    $bg3
client.urgent           $red    $red  $fg    $red    $red

# gaps
gaps inner 2
gaps outer 1
smart_gaps on
smart_borders on
